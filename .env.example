MINICLAW_API_KEY=your-api-key
MINICLAW_BASE_URL=https://openrouter.ai/api/v1
MINICLAW_MODEL=gpt-4o-mini

# MINICLAW_DEBUG=false

# Runtime
# MINICLAW_SQLITE_PATH=/mnt/d/Projects/nanobot/miniclaw/.miniclaw/miniclaw.sqlite3
# MINICLAW_DEFAULT_THREAD_ID=default
# MINICLAW_LOG_LEVEL=INFO
# MINICLAW_SYSTEM_PROMPT=

# Telegram
# MINICLAW_TELEGRAM_BOT_TOKEN=123456:telegram-bot-token
# MINICLAW_HEARTBEAT_CHAT_ID=
# MINICLAW_HEARTBEAT_MESSAGE_THREAD_ID=

# Tracing
# MINICLAW_TRACE_MODE=off
# MINICLAW_TRACE_DIR=/mnt/d/Projects/nanobot/miniclaw/.miniclaw/traces
# MINICLAW_TRACE_FULL_CONTENT=false
# MINICLAW_TRACE_MAX_CHARS=4000
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=miniclaw
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Search
# MINICLAW_SEARCH_PROVIDER=none
# MINICLAW_SEARCH_API_KEY=
# MINICLAW_SEARCH_BASE_URL=
# MINICLAW_SEARCH_PROXY=
# MINICLAW_SEARCH_MAX_RESULTS=5

# Prompt caching strategy: auto | anthropic | openai_auto | none
# auto: detect from base_url (anthropic/dashscope -> anthropic, openai -> openai_auto, other -> none)
# anthropic: explicit cache_control: ephemeral on system static segment (BP2)
# openai_auto: rely on OpenAI's automatic prefix caching (>=1024 tokens)
# none: no caching
# MINICLAW_CACHE_STRATEGY=auto

# DEPRECATED: use MINICLAW_CACHE_STRATEGY instead. Removed in a future release.
# MINICLAW_ENABLE_PROMPT_CACHE=false

# Compression promotion (Phase 5)
# When True, _trim_history schedules an LLM extraction job to promote facts
# from compressed messages into long-term memory and the daily MD journal.
# MINICLAW_COMPRESSION_EXTRACT_ENABLED=true

# Which model tier to use for the extraction call.
# mini = use mini_model (cheaper); main = use main model; auto = mini if available
# MINICLAW_COMPRESSION_EXTRACT_MODEL_TIER=mini

# Timeout (seconds) for the extraction LLM call.
# MINICLAW_COMPRESSION_EXTRACT_TIMEOUT_S=15.0

# Pinned reference extraction (always synchronous, regex-based; Phase 4).
# MINICLAW_COMPRESSION_PINNED_EXTRACT_ENABLED=true

# Runtime limits
# MINICLAW_MAX_TOOL_ROUNDS=16
# MINICLAW_MAX_CONSECUTIVE_TOOL_ERRORS=4
# MINICLAW_MAX_TOOL_RESULT_CHARS=16000
# MINICLAW_MAX_READ_FILE_BYTES=32768
# MINICLAW_HISTORY_CHAR_BUDGET=60000
